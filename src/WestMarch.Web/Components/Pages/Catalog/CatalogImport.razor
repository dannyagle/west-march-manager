@page "/catalog/import"
@attribute [Authorize(Policy = AuthPolicies.RequireCa)]
@rendermode InteractiveServer

@using WestMarch.Application.Bestiary
@using WestMarch.Application.Items
@using WestMarch.Domain.Items

@inject ICatalogService Catalog
@inject ICatalogFileParser Parser
@inject IMonsterService MonsterSvc
@inject IMonsterFileParser MonsterParser

<PageTitle>Import Reference Files</PageTitle>

<div class="wm-panel" style="max-width:860px;margin:0 auto">
    <h1>Refresh the reference ledgers</h1>
    <p class="meta">
        Upload a new items or monsters file. Existing entries are matched by name (items:
        name + rarity): changed entries are updated, new ones added, and entries missing from
        the file are <b>retired, never deleted</b> (owned copies, encounters, and history
        survive). Custom items and campaign price overrides are untouched.
    </p>

    @if (error is not null)
    {
        <div class="alert alert-danger">@error</div>
    }
    @if (appliedSummary is not null)
    {
        <div class="alert alert-success">@appliedSummary</div>
    }

    <div class="field-row" style="align-items:flex-end">
        <div class="field" style="max-width:200px">
            <label>File kind</label>
            <select @bind="kind">
                <option value="@ImportFileKind.Magic">Magic items</option>
                <option value="@ImportFileKind.Mundane">Mundane equipment</option>
                <option value="@ImportFileKind.Monster">Monsters (bestiary)</option>
            </select>
        </div>
        <div class="field">
            <label>JSON file</label>
            <InputFile OnChange="OnFileSelectedAsync" accept="application/json,.json" />
        </div>
    </div>

    @if (added is not null)
    {
        <div class="rule-title">What this import will do</div>
        <p class="meta">
            <b>@added.Count</b> added · <b>@updated.Count</b> updated ·
            <b>@deactivated.Count</b> retired · @unchangedCount unchanged
        </p>

        @foreach (var (title, changes) in new[] { ("Added", added), ("Updated", updated), ("Retired (missing from file)", deactivated) })
        {
            @if (changes.Count > 0)
            {
                <details style="margin-bottom:0.6rem" open="@(changes.Count <= 12)">
                    <summary style="cursor:pointer">@title (@changes.Count)</summary>
                    <table class="wm-table">
                        <tbody>
                            @foreach (var change in changes)
                            {
                                <tr>
                                    <td>@change.Name</td>
                                    <td>
                                        @if (change.Rarity is not null and not ItemRarity.None)
                                        {
                                            <RarityChip Rarity="change.Rarity.Value" />
                                        }
                                        else if (change.Cr is not null)
                                        {
                                            <span class="tag-chip">CR @change.Cr</span>
                                        }
                                    </td>
                                    <td class="meta">@change.Detail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </details>
            }
        }

        <div style="display:flex;gap:0.8rem;margin-top:1rem">
            <button class="btn btn-primary" @onclick="ApplyAsync" disabled="@applying">Apply import</button>
            <button class="btn" @onclick="Reset">Discard</button>
        </div>
    }

    <div class="rule-title">Import history</div>
    @if (batches is null || batches.Count == 0)
    {
        <p class="meta">No imports recorded yet.</p>
    }
    else
    {
        <table class="wm-table">
            <thead><tr><th>When</th><th>File</th><th>Kind</th><th>Changes</th><th>Source</th></tr></thead>
            <tbody>
                @foreach (var b in batches)
                {
                    <tr>
                        <td class="meta">@b.UploadedAt.LocalDateTime.ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@b.FileName</td>
                        <td class="meta">@b.Kind</td>
                        <td class="meta">+@b.AddedCount ~@b.UpdatedCount −@b.DeactivatedCount</td>
                        <td class="meta" title="@b.SourceNote">@Truncate(b.SourceNote)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private sealed record ChangeRow(string Name, ItemRarity? Rarity, string? Cr, string Detail);

    private ImportFileKind kind = ImportFileKind.Magic;
    private ParsedCatalogFile? parsedItems;
    private ParsedMonsterFile? parsedMonsters;
    private string? fileName;
    private string? appliedSummary;

    private List<ChangeRow>? added;
    private List<ChangeRow> updated = [];
    private List<ChangeRow> deactivated = [];
    private int unchangedCount;

    private IReadOnlyList<ImportBatch>? batches;
    private string? error;
    private bool applying;

    protected override async Task OnInitializedAsync() =>
        batches = await Catalog.ListImportBatchesAsync();

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        error = null;
        appliedSummary = null;
        Reset();

        try
        {
            // Buffer the browser stream so parse + apply don't re-read it.
            using var memory = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024).CopyToAsync(memory);
            memory.Position = 0;
            fileName = e.File.Name;

            if (kind == ImportFileKind.Monster)
            {
                parsedMonsters = await MonsterParser.ParseAsync(memory);
                var preview = await MonsterSvc.PreviewImportAsync(parsedMonsters);
                added = [.. preview.Added.Select(c => new ChangeRow(c.Name, null, c.ChallengeRating, c.Detail))];
                updated = [.. preview.Updated.Select(c => new ChangeRow(c.Name, null, c.ChallengeRating, c.Detail))];
                deactivated = [.. preview.Deactivated.Select(c => new ChangeRow(c.Name, null, c.ChallengeRating, c.Detail))];
                unchangedCount = preview.UnchangedCount;
            }
            else
            {
                parsedItems = await Parser.ParseAsync(memory, (ItemKind)(int)kind);
                var preview = await Catalog.PreviewImportAsync(parsedItems);
                added = [.. preview.Added.Select(c => new ChangeRow(c.Name, c.Rarity, null, c.Detail))];
                updated = [.. preview.Updated.Select(c => new ChangeRow(c.Name, c.Rarity, null, c.Detail))];
                deactivated = [.. preview.Deactivated.Select(c => new ChangeRow(c.Name, c.Rarity, null, c.Detail))];
                unchangedCount = preview.UnchangedCount;
            }
        }
        catch (AppValidationException ex)
        {
            error = ex.Message;
            Reset();
        }
        catch (IOException)
        {
            error = "That file is too large (8 MB max).";
            Reset();
        }
    }

    private async Task ApplyAsync()
    {
        if (fileName is null)
        {
            return;
        }

        applying = true;
        error = null;
        try
        {
            var batch = kind == ImportFileKind.Monster
                ? await MonsterSvc.ApplyImportAsync(parsedMonsters!, fileName)
                : await Catalog.ApplyImportAsync(parsedItems!, fileName);

            appliedSummary = $"Imported {batch.FileName}: {batch.AddedCount} added, {batch.UpdatedCount} updated, " +
                             $"{batch.DeactivatedCount} retired, {batch.UnchangedCount} unchanged.";
            Reset();
            batches = await Catalog.ListImportBatchesAsync();
        }
        catch (Exception ex) when (ex is AppValidationException or ForbiddenAccessException)
        {
            error = ex.Message;
        }
        finally
        {
            applying = false;
        }
    }

    private void Reset()
    {
        parsedItems = null;
        parsedMonsters = null;
        fileName = null;
        added = null;
        updated = [];
        deactivated = [];
        unchangedCount = 0;
    }

    private static string Truncate(string? s) =>
        s is null ? "—" : s.Length <= 40 ? s : s[..40] + "…";
}
