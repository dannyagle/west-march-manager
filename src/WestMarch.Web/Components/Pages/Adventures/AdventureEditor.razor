@page "/adventures/new"
@page "/adventures/{Id:guid}/edit"
@attribute [Authorize(Policy = AuthPolicies.RequireDm)]
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using WestMarch.Application.Adventures
@using WestMarch.Application.Items
@using WestMarch.Domain.Items

@inject IAdventureService Adventures
@inject ICatalogService Catalog
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Author an Adventure" : "Edit Adventure")</PageTitle>

<div class="wm-panel" style="max-width:860px;margin:0 auto">
    <h1>@(IsNew ? "Author an adventure" : $"Edit: {model.Title}")</h1>
    <p class="meta">Drafts are visible only to you (and Campaign Admins) until you mark them ready for review.</p>

    @if (errors is not null)
    {
        <div class="alert alert-danger">@string.Join(" ", errors)</div>
    }

    <EditForm Model="model" OnValidSubmit="SaveAsync" FormName="adventure-editor">
        <DataAnnotationsValidator />

        <div class="field">
            <label>Title</label>
            <InputText @bind-Value="model.Title" placeholder="e.g. The Sunken Vault of Aldremir" />
            <ValidationMessage For="() => model.Title" />
        </div>

        <div class="field-row">
            <div class="field">
                <label>Min level</label>
                <InputNumber @bind-Value="model.MinLevel" />
            </div>
            <div class="field">
                <label>Max level</label>
                <InputNumber @bind-Value="model.MaxLevel" />
            </div>
            <div class="field">
                <label>Seats (min)</label>
                <InputNumber @bind-Value="model.TargetPlayersMin" />
            </div>
            <div class="field">
                <label>Seats (max)</label>
                <InputNumber @bind-Value="model.TargetPlayersMax" />
            </div>
        </div>

        <div class="field">
            <label>Short description <span class="meta">(public teaser on the quest board)</span></label>
            <InputTextArea @bind-Value="model.ShortDescription" rows="2" />
            <ValidationMessage For="() => model.ShortDescription" />
        </div>

        <div class="field">
            <label>Long description <span class="meta">(public)</span></label>
            <InputTextArea @bind-Value="model.LongDescription" rows="5" />
            <ValidationMessage For="() => model.LongDescription" />
        </div>

        <div class="field">
            <label>DM notes <span class="meta">(DMs &amp; CAs only)</span></label>
            <InputTextArea @bind-Value="model.DmNotes" rows="4" />
        </div>

        <div class="field">
            <label>Monster stat blocks <span class="meta">(DMs &amp; CAs only)</span></label>
            <InputTextArea @bind-Value="model.MonsterStatBlocks" rows="5" placeholder="e.g. 8× Goblin (MM p.166)…" />
        </div>

        <div class="field-row">
            <div class="field">
                <label>Active from</label>
                <InputDate @bind-Value="model.ActiveFrom" />
            </div>
            <div class="field">
                <label>Active until <span class="meta">(blank = forever)</span></label>
                <InputDate @bind-Value="model.ActiveUntil" />
            </div>
        </div>

        <div class="field">
            <label>Tags <span class="meta">(comma-separated, e.g. horror, epic event)</span></label>
            <InputText @bind-Value="model.TagsText" placeholder="wilderness, mystery" />
        </div>

        <div class="rule-title">Rewards</div>
        <p class="meta">Every character who completes the session receives all of these.</p>
        @foreach (var reward in model.GuaranteedRewards)
        {
            var r = reward;
            <div class="reward-block">
                <div class="field-row">
                    <div class="field" style="max-width:140px">
                        <label>Kind</label>
                        <InputSelect @bind-Value="r.Kind">
                            <option value="@RewardKind.Gold">Gold</option>
                            <option value="@RewardKind.Item">Item</option>
                            <option value="@RewardKind.Other">Other</option>
                        </InputSelect>
                    </div>
                    @if (r.Kind == RewardKind.Gold)
                    {
                        <div class="field" style="max-width:140px">
                            <label>Amount (gp)</label>
                            <InputNumber @bind-Value="r.GoldAmount" />
                        </div>
                    }
                    <div class="field">
                        <label>Description</label>
                        <InputText @bind-Value="r.Description" placeholder="e.g. 150 gp Warden bounty" />
                    </div>
                    <div class="field" style="max-width:90px;align-self:flex-end">
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => model.GuaranteedRewards.Remove(r)">Remove</button>
                    </div>
                </div>
            </div>
        }
        <button type="button" class="btn btn-sm" @onclick="() => model.GuaranteedRewards.Add(new())">+ Add reward</button>

        <h3 style="margin-top:1.5rem">Choices — each character picks one</h3>
        <p class="meta">
            Pick options from the item catalog (players receive a real, tradeable item) or write free
            text (noted on the character's ledger for their sheet). The catalog list shows rarities
            fitting levels @model.MinLevel–@model.MaxLevel by default.
        </p>
        <label style="display:flex;align-items:center;text-transform:none;letter-spacing:normal;margin-bottom:0.6rem">
            <input type="checkbox" @bind="showOffTier" />
            Include items outside this adventure's level range <span class="meta">&nbsp;(special adventures — the reviewing CA sees a flag)</span>
        </label>
        @foreach (var set in model.OptionSets)
        {
            var s = set;
            <div class="reward-block">
                <div style="display:flex;align-items:baseline;justify-content:space-between">
                    <div class="reward-kicker">Choose one of @s.Options.Count</div>
                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => model.OptionSets.Remove(s)">Remove choice</button>
                </div>
                @foreach (var option in s.Options)
                {
                    var o = option;
                    var linked = LinkedItem(o);
                    <div class="field-row" style="margin-left:1rem">
                        <div class="field" style="max-width:320px">
                            <label>Catalog item</label>
                            <select value="@(o.CatalogItemId?.ToString() ?? "")" @onchange="e => SetOptionItem(o, e)">
                                <option value="">— free text —</option>
                                @foreach (var item in PickableItems(o))
                                {
                                    <option value="@item.Id">@item.Name (@item.Rarity.Display()@(item.EffectivePriceGp is not null ? $", {item.EffectivePriceGp} gp" : ""))</option>
                                }
                            </select>
                        </div>
                        @if (linked is null)
                        {
                            <div class="field">
                                <label>Option text</label>
                                <InputText @bind-Value="o.Description" placeholder="e.g. Vex's map satchel" />
                            </div>
                            <div class="field">
                                <label>Link <span class="meta">(optional)</span></label>
                                <InputText @bind-Value="o.ExternalUrl" placeholder="https://…" />
                            </div>
                        }
                        else
                        {
                            <div class="field" style="align-self:flex-end;padding-bottom:0.35rem">
                                <RarityChip Rarity="linked.Rarity" />
                                <ItemPrice Item="linked" />
                                @if (!RarityTiers.IsAppropriateFor(linked.Rarity, model.MinLevel, model.MaxLevel))
                                {
                                    <span class="seal seal-needsdm" title="Outside this adventure's level range — the reviewing CA will see this flag">off-tier</span>
                                }
                            </div>
                        }
                        <div class="field" style="max-width:90px;align-self:flex-end">
                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => s.Options.Remove(o)">×</button>
                        </div>
                    </div>
                }
                <button type="button" class="btn btn-sm" style="margin-left:1rem" @onclick="() => s.Options.Add(new())">+ Add option</button>
            </div>
        }
        <button type="button" class="btn btn-sm" @onclick="AddOptionSet">+ Add choice</button>

        @* Validation feedback belongs next to the submit button too — the page is long
           and field-level messages can be scrolled out of view. *@
        <ValidationSummary class="text-danger" role="alert" style="margin-top:1.4rem" />
        @if (errors is not null)
        {
            <div class="alert alert-danger" style="margin-top:1rem">@string.Join(" ", errors)</div>
        }

        <div style="display:flex;gap:0.8rem;margin-top:1rem">
            <button type="submit" class="btn btn-primary" disabled="@saving">@(IsNew ? "Create draft" : "Save changes")</button>
            <a class="btn" href="@(IsNew ? "adventures" : $"adventures/{Id}")">Cancel</a>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsNew => Id is null;
    private FormModel model = new();
    private IReadOnlyList<string>? errors;
    private bool saving;
    private bool loaded;

    private IReadOnlyList<CatalogItem> catalogItems = [];
    private bool showOffTier;

    private CatalogItem? LinkedItem(OptionRow o) =>
        o.CatalogItemId is null ? null : catalogItems.FirstOrDefault(c => c.Id == o.CatalogItemId);

    /// <summary>Tier-filtered picker contents; the currently linked item always stays visible.</summary>
    private IEnumerable<CatalogItem> PickableItems(OptionRow o) => catalogItems
        .Where(c => c.Id == o.CatalogItemId
            || showOffTier
            || RarityTiers.IsAppropriateFor(c.Rarity, model.MinLevel, model.MaxLevel));

    private void SetOptionItem(OptionRow o, ChangeEventArgs e)
    {
        o.CatalogItemId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        if (LinkedItem(o) is { } item)
        {
            o.Description = item.Name;
            o.ExternalUrl = null;
        }
    }

    protected override async Task OnInitializedAsync() =>
        catalogItems = await Catalog.ListAsync(new CatalogFilter(Kind: ItemKind.Magic));

    protected override async Task OnParametersSetAsync()
    {
        if (Id is not null && !loaded)
        {
            loaded = true;
            var a = await Adventures.GetAsync(Id.Value);
            model = new FormModel
            {
                Title = a.Title,
                MinLevel = a.MinLevel,
                MaxLevel = a.MaxLevel,
                TargetPlayersMin = a.TargetPlayersMin,
                TargetPlayersMax = a.TargetPlayersMax,
                ShortDescription = a.ShortDescription,
                LongDescription = a.LongDescription,
                DmNotes = a.DmNotes,
                MonsterStatBlocks = a.MonsterStatBlocks,
                ActiveFrom = DateOnly.FromDateTime(a.ActiveFrom.LocalDateTime),
                ActiveUntil = a.ActiveUntil is null ? null : DateOnly.FromDateTime(a.ActiveUntil.Value.LocalDateTime),
                TagsText = string.Join(", ", a.Tags.Select(t => t.Name)),
                GuaranteedRewards = [.. a.GuaranteedRewards.Select(r => new RewardRow
                {
                    Kind = r.Kind, GoldAmount = r.GoldAmount, Description = r.Description,
                })],
                OptionSets = [.. a.RewardOptionSets.Select(s => new OptionSetRow
                {
                    Name = s.Name,
                    Options = [.. s.Options.Select(o => new OptionRow
                    {
                        Description = o.Description,
                        ExternalUrl = o.ExternalUrl,
                        CatalogItemId = o.CatalogItemId,
                    })],
                })],
            };
        }
    }

    private void AddOptionSet() =>
        model.OptionSets.Add(new OptionSetRow { Options = [new(), new()] });

    private async Task SaveAsync()
    {
        saving = true;
        errors = null;
        try
        {
            var input = new AdventureInput(
                model.Title,
                model.MinLevel,
                model.MaxLevel,
                model.TargetPlayersMin,
                model.TargetPlayersMax,
                model.ShortDescription,
                model.LongDescription,
                model.DmNotes,
                model.MonsterStatBlocks,
                new DateTimeOffset(model.ActiveFrom, TimeOnly.MinValue, DateTimeOffset.Now.Offset),
                model.ActiveUntil is null ? null : new DateTimeOffset(model.ActiveUntil.Value, new TimeOnly(23, 59), DateTimeOffset.Now.Offset),
                [.. model.TagsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)],
                [.. model.GuaranteedRewards.Select(r => new RewardComponentInput(r.Kind, r.GoldAmount, r.Description))],
                [.. model.OptionSets.Select(s => new RewardOptionSetInput(
                    s.Name,
                    [.. s.Options.Select(o => new RewardOptionInput(o.Description, o.ExternalUrl, o.CatalogItemId))]))]);

            var saved = IsNew
                ? await Adventures.CreateAsync(input)
                : await Adventures.UpdateAsync(Id!.Value, input);

            Nav.NavigateTo($"adventures/{saved.Id}");
        }
        catch (AppValidationException ex)
        {
            errors = ex.Errors;
        }
        finally
        {
            saving = false;
        }
    }

    private sealed class FormModel
    {
        [Required, StringLength(150)]
        public string Title { get; set; } = "";

        public int MinLevel { get; set; } = 3;
        public int MaxLevel { get; set; } = 5;
        public int TargetPlayersMin { get; set; } = 4;
        public int TargetPlayersMax { get; set; } = 6;

        [Required, StringLength(500)]
        public string ShortDescription { get; set; } = "";

        [Required]
        public string LongDescription { get; set; } = "";

        public string? DmNotes { get; set; }
        public string? MonsterStatBlocks { get; set; }

        public DateOnly ActiveFrom { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public DateOnly? ActiveUntil { get; set; }

        public string TagsText { get; set; } = "";

        public List<RewardRow> GuaranteedRewards { get; set; } = [];
        public List<OptionSetRow> OptionSets { get; set; } = [];
    }

    private sealed class RewardRow
    {
        public RewardKind Kind { get; set; } = RewardKind.Gold;
        public int? GoldAmount { get; set; }
        public string Description { get; set; } = "";
    }

    private sealed class OptionSetRow
    {
        public string Name { get; set; } = "";
        public List<OptionRow> Options { get; set; } = [];
    }

    private sealed class OptionRow
    {
        public string Description { get; set; } = "";
        public string? ExternalUrl { get; set; }
        public Guid? CatalogItemId { get; set; }
    }
}
